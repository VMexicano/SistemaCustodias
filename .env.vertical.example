# =============================================================================
# Variables de entorno relacionadas con el vertical activo
# Copiar como .env en apps/api/ y ajustar según el vertical a desplegar.
# =============================================================================

# ----- VERTICAL ACTIVO -------------------------------------------------------
# Identifica qué vertical sirve GET /config y controla feature flags en la API.
# Valores disponibles: taxi | custody | cold-chain | (slug de tu vertical)
VERTICAL_SLUG=taxi

# ----- BACKOFFICE WEB (apps/web) ---------------------------------------------
# Expuesto vía Vite como import.meta.env.VITE_VERTICAL_SLUG
# Debe coincidir con VERTICAL_SLUG para que la UI resalte el vertical activo.
VITE_VERTICAL_SLUG=taxi

# ----- MOBILE (apps/mobile-v2) -----------------------------------------------
# En app.json o app.config.js, dentro de la sección "extra":
#   "extra": { "verticalSlug": "taxi" }
# Luego acceder con: import Constants from 'expo-constants';
# Constants.expoConfig?.extra?.verticalSlug

# ----- BASE DE DATOS ----------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uber_base

# ----- REDIS ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ----- JWT -------------------------------------------------------------------
JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_refresh_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ----- SERVIDOR ---------------------------------------------------------------
NODE_ENV=development
PORT=3333
CORS_ORIGIN=http://localhost:5173

# ----- OTP -------------------------------------------------------------------
# "log" para desarrollo (imprime OTP en consola), "firebase" para producción
OTP_PROVIDER=log

# Credenciales Firebase (solo si OTP_PROVIDER=firebase)
# FIREBASE_PROJECT_ID=tu-proyecto
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@tu-proyecto.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ----- STRIPE ----------------------------------------------------------------
# Clave de prueba para desarrollo
# STRIPE_SECRET_KEY=sk_test_...

# ----- OBSERVABILIDAD (opcional) ---------------------------------------------
LOG_LEVEL=info
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
