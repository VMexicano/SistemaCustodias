{
  "name": "mobile-v2",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:e2e": "maestro test e2e/flows/",
    "test:e2e:auth": "maestro test e2e/flows/auth.yaml",
    "test:e2e:passenger": "maestro test e2e/flows/passenger.yaml",
    "test:e2e:driver": "maestro test e2e/flows/driver.yaml",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/stack": "^7.1.1",
    "@rnmapbox/maps": "^10.3.0",
    "@tanstack/react-query": "^5.56.0",
    "axios": "^1.7.9",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-image-picker": "~17.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^3.2.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "socket.io-client": "^4.8.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@types/react-native": "^0.73.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "reactotron-react-native": "^5.1.18",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "react-native-mmkv": "<rootDir>/src/__mocks__/react-native-mmkv.ts"
    },
    "collectCoverageFrom": [
      "src/stores/**/*.ts",
      "src/services/**/*.ts",
      "src/screens/**/*.tsx",
      "!src/**/__mocks__/**",
      "!src/**/*.d.ts"
    ]
  },
  "private": true
}
