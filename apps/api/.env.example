# === Servidor ===
NODE_ENV=development
PORT=3333

# === Base de datos ===
DATABASE_URL=postgresql://ridebase_user:ridebase_pass@localhost:5432/ridebase_dev

# === Redis ===
REDIS_URL=redis://localhost:6379

# === JWT ===
# IMPORTANTE: Cambiar por strings aleatorios de 64+ caracteres en produccion
JWT_SECRET=change-me-use-a-random-64-char-string-in-production-never-commit
JWT_REFRESH_SECRET=change-me-use-another-random-64-char-string-different-from-above
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
TRIP_SEARCHING_TIMEOUT_MS=300000

# === App ===
APP_URL=http://localhost:3333
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# === Test mode ===
# true -> OTP fijo = 123456, no envia SMS reales, Stripe en modo test
TEST_MODE=false

# === E2E test OTP bypass (solo para Detox / Playwright E2E) ===
# TEST_OTP_BYPASS=true omite la validación Redis en verifyPhone
# Requiere también TEST_OTP_CODE con el código aceptado
TEST_OTP_BYPASS=false
TEST_OTP_CODE=123456

# === Observabilidad ===
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# === OTP ===
# Opciones: log (desarrollo) | firebase (produccion)
OTP_PROVIDER=log

# === Firebase Admin SDK (requerido solo si OTP_PROVIDER=firebase) ===
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# === Stripe ===
# Obtener en https://dashboard.stripe.com/test/apikeys
# En desarrollo usar la clave de prueba (sk_test_...)
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_test_key

# === Multi-vertical (Sprint 10 — ADR-036) ===
# Slug del vertical activo en esta instancia (taxi | custody | cold-chain)
VERTICAL_SLUG=taxi
