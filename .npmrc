shamefully-hoist=false
strict-peer-dependencies=false
public-hoist-pattern[]=@react-native*
public-hoist-pattern[]=react-native*

# Windows: pnpm virtual store paths exceed MAX_PATH (260) when combined with
# Android CMake build intermediates. node-linker=hoisted puts real files in
# node_modules/pkg-name instead of symlinks into .pnpm/pkg@version/.../pkg-name,
# reducing the path to ~172 chars (vs 311 with isolated mode).
node-linker=hoisted
