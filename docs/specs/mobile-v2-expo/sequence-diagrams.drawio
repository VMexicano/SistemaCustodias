          </mxGeometry>
        </mxCell>
        <mxCell id="gl2" value="" style="endArrow=none;dashed=1;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="82" as="sourcePoint" /><mxPoint x="300" y="750" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="gl3" value="" style="endArrow=none;dashed=1;strokeColor=#82b366;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="82" as="sourcePoint" /><mxPoint x="550" y="750" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="gl4" value="" style="endArrow=none;dashed=1;strokeColor=#6c8ebf;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="780" y="82" as="sourcePoint" /><mxPoint x="780" y="750" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- Precondición -->
        <mxCell id="gpre" value="[Viaje aceptado — ver diagrama 2, paso 9]" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=center;whiteSpace=wrap;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="10" y="100" width="270" height="25" as="geometry" />
        </mxCell>

        <!-- 1. startTracking -->
        <mxCell id="gm1" value="1. LocationService.startTracking(tripId)" style="html=1;endArrow=block;endFill=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="145" as="sourcePoint" /><mxPoint x="300" y="145" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 2. requestBackgroundPermissions -->
        <mxCell id="gm2" value="2. requestBackgroundPermissionsAsync() — dialog al usuario" style="html=1;endArrow=block;endFill=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="190" as="sourcePoint" /><mxPoint x="100" y="190" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="gm2b" value="2b. &quot;Permitir siempre&quot; — granted" style="html=1;endArrow=open;endFill=0;dashed=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="230" as="sourcePoint" /><mxPoint x="300" y="230" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 3. startLocationUpdatesAsync -->
        <mxCell id="gm3" value="3. startLocationUpdatesAsync(LOCATION_TASK, { accuracy: High, distanceInterval: 10m, timeInterval: 5000, foregroundService: {...} })" style="html=1;endArrow=block;endFill=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="275" as="sourcePoint" /><mxPoint x="300" y="275" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="gn1" value="Android: ForegroundService activo&#xa;Notificación persistente en status bar" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=center;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="215" y="298" width="200" height="38" as="geometry" />
        </mxCell>

        <!-- Loop label -->
        <mxCell id="gloop" value="↺  LOOP — Android OS dispara LOCATION_TASK cada 5 s (pantalla apagada, app en background)" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=center;whiteSpace=wrap;rounded=1;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="10" y="358" width="600" height="28" as="geometry" />
        </mxCell>

        <!-- 4. Task fires -->
        <mxCell id="gm4" value="4. LOCATION_TASK fires { locations: [{ lat, lng, speed, bearing }] }" style="html=1;endArrow=block;endFill=1;fontSize=11;labelBackgroundColor=#ffffff;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="405" as="sourcePoint" /><mxPoint x="100" y="405" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 5. emit driver:location -->
        <mxCell id="gm5" value="5. socketClient.emit(&quot;driver:location&quot;, { tripId, lat, lng })" style="html=1;endArrow=block;endFill=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="455" as="sourcePoint" /><mxPoint x="550" y="455" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 6. API → Redis publish -->
        <mxCell id="gm6" value="6. Redis PUBLISH trip:{id}:location { lat, lng }" style="html=1;endArrow=block;endFill=1;fontSize=11;labelBackgroundColor=#ffffff;strokeColor=#82b366;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="500" as="sourcePoint" /><mxPoint x="550" y="500" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="gm6-note" value="API recibe evento → Redis PUBLISH (pub/sub entre instancias)" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=center;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="460" y="480" width="260" height="30" as="geometry" />
        </mxCell>

        <!-- 7. emit trip:driver_location to pasajero -->
        <mxCell id="gm7" value="7. emit &quot;trip:driver_location&quot; { lat, lng } (WebSocket)" style="html=1;endArrow=open;endFill=1;dashed=1;fontSize=11;labelBackgroundColor=#ffffff;strokeColor=#6c8ebf;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="530" as="sourcePoint" /><mxPoint x="780" y="530" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="gm7-note" value="Pasajero actualiza marcador del conductor en mapa (ActiveTripScreen)" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=center;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="660" y="548" width="210" height="35" as="geometry" />
        </mxCell>

        <!-- Offline queue branch -->
        <mxCell id="goffline" value="⚠ Si Socket desconectado: coords se encolan en MMKV. Al reconectar → replay automático de la cola." style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=center;whiteSpace=wrap;rounded=1;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="10" y="595" width="430" height="35" as="geometry" />
        </mxCell>

        <!-- Stop tracking -->
        <mxCell id="gstop-label" value="Al completar o cancelar viaje:" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="10" y="652" width="220" height="20" as="geometry" />
        </mxCell>
        <mxCell id="gm8" value="8. LocationService.stopTracking()" style="html=1;endArrow=block;endFill=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="682" as="sourcePoint" /><mxPoint x="300" y="682" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="gm9" value="9. stopLocationUpdatesAsync(LOCATION_TASK) — ForegroundService termina" style="html=1;endArrow=open;endFill=0;dashed=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="718" as="sourcePoint" /><mxPoint x="100" y="718" as="targetPoint" />
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

