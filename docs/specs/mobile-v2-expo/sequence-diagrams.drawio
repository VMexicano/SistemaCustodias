        <mxCell id="g3" value="API WebSocket&#xa;+ Redis" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="470" y="32" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="g4" value="App Pasajero" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="32" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Lifelines -->
        <mxCell id="gl1" value="" style="endArrow=none;dashed=1;strokeColor=#9673a6;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
